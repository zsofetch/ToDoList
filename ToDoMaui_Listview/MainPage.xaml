<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ToDoMaui_Listview.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F5F0E6">

    <Grid RowDefinitions="Auto, Auto, Auto, *" Padding="20" RowSpacing="15">

        <HorizontalStackLayout Grid.Row="0" Spacing="15" VerticalOptions="Center">
            <ImageButton Source="back_icon.png" BackgroundColor="#EBE3D5" CornerRadius="15" WidthRequest="30" HeightRequest="30" Clicked="OnBackClicked" />
            <Label Text="Welcome!" FontSize="24" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <Border Grid.Row="1" BackgroundColor="#EBE3D5" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="15">
            <VerticalStackLayout Spacing="10">
                <Entry x:Name="titleEntry" Placeholder="Tag (e.g., acads, chores)" PlaceholderColor="#999" TextColor="Black" BackgroundColor="White" />
                <Entry x:Name="detailsEntry" Placeholder="Task Details" PlaceholderColor="#999" TextColor="Black" BackgroundColor="White" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button x:Name="addBtn" Grid.ColumnSpan="2" Text="Add Task" TextColor="#5C6B47" BackgroundColor="#D5E6A3" CornerRadius="20" Clicked="AddToDoItem" FontAttributes="Bold"/>
                    <Button x:Name="editBtn" Grid.Column="0" IsVisible="False" Text="Save" TextColor="White" BackgroundColor="#8AA399" CornerRadius="20" Clicked="EditToDoItem"/>
                    <Button x:Name="cancelBtn" Grid.Column="1" IsVisible="False" Text="Cancel" TextColor="White" BackgroundColor="#E5B8B7" CornerRadius="20" Clicked="CancelEdit"/>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Label Grid.Row="2" Text="To do today:" TextColor="#555" Margin="0,5,0,0" />

        <CollectionView Grid.Row="3" x:Name="todoCV" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#EBE3D5" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="15,15" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="10">

                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="5">
                                <Border BackgroundColor="#F4ACB7" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="10,4" HorizontalOptions="Start">
                                    <Label Text="{Binding title}" FontSize="10" FontAttributes="Bold" TextColor="White" TextTransform="Uppercase" />
                                </Border>
                                <Label Text="{Binding detail}" FontSize="14" TextColor="#333333" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1" Text="Edit" BackgroundColor="Transparent" TextColor="#8AA399" 
                                    ClassId="{Binding id}" Clicked="OnEditIconClicked" FontSize="16" Padding="0" VerticalOptions="Center" WidthRequest="30" HeightRequest="30"/>

                            <CheckBox Grid.Column="2" IsChecked="{Binding IsCompleted}" Color="#5C6B47" VerticalOptions="Center" />

                            <Button Grid.Column="3" Text="✕" BackgroundColor="Transparent" TextColor="#A0A0A0" 
                                    ClassId="{Binding id}" Clicked="DeleteToDoItem" FontSize="16" Padding="0" VerticalOptions="Center" WidthRequest="30" HeightRequest="30"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>